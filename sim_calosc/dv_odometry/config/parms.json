      "imu_ay": {
        "history_size_samples": 7,
        "relative_deviation_threshold": 2.5,
        "relative_deviation_ref_epsilon": 0.20,
        "absolute_reject_threshold": 15.0,
        "max_consecutive_rejects": 2
      },
      "imu_yaw_rate": {
        "history_size_samples": 7,
        "relative_deviation_threshold": 2.5,
        "relative_deviation_ref_epsilon": 0.05,
        "absolute_reject_threshold": 4.0,
        "max_consecutive_rejects": 2
      }
    },

    "heuristic_windows": {
      "ax_time": 0.15,
      "ay_time": 0.15,
      "torque_cmd_time": 0.15,
      "steer_dot_time": 0.15,
