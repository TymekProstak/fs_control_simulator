	<!-- <link name="base_link" />
	<joint name="CoG_joint" type="fixed">
		<origin xyz="1.7 0 0" rpy="0 0 0" />
		<parent link="DVCar"/>
		<child link="base_link"/>
	</joint> -->

    <link name="camera_base" />
	<joint name="camera_joint" type="fixed">
		<origin xyz="-1.9 0 0.9" rpy="0 0 0" />
		<parent link="base_link"/>
		<child link="camera_base"/>
	</joint>

    <link name="os_sensor" />
    <joint name="lidar_joint" type="fixed">
		<origin xyz="-0.58 0 0.44" rpy="0 0.213 0"/> <!-- Value 0.213 should be chaneged on real car before tests. Depends on the lidar mounting -->
		<parent link="base_link"/>
		<child link="os_sensor"/>
	</joint>

	<link name="gps" />
    <joint name="gps_joint" type="fixed">
		<origin xyz="-0.5 -0.2 0" rpy="0 0 0"/>
		<parent link="base_link"/>
		<child link="gps"/>
	</joint>


