<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="bolid">

	<!-- <material name="gray">
    	<color rgba="0.6 0.6 0.6 1"/>
  	</material> -->

	<link name="bolide_CoG" />

	<!-- bolid_base is CoG - center of gravity -->
	<link name="base_link" /> 
	<joint name="CoG_joint" type="fixed">
		<origin xyz="1.7 0 0" rpy="0 0 0" />
		<parent link="bolide_CoG"/>
		<child link="base_link"/>
	</joint>
